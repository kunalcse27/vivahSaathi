# ── Copy this to .env and fill in your values ──

# SQLite (dev, default — works with no setup):
# DATABASE_URL=sqlite:///./vivahsaathi_dev.db

# MySQL (production):
DATABASE_URL=mysql+pymysql://root:root@localhost:3306/vivahsaathi

# Razorpay (get from razorpay.com → Settings → API Keys)
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=secreat_key_to_fill_here

# Webhook secret (from Razorpay → Settings → Webhooks → Secret)
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# CORS — your frontend domain (comma-separated)
ALLOWED_ORIGINS=http://127.0.0.1:5500

# Upload settings
UPLOAD_MAX_MB=5